#!/usr/bin/env bash
# =============================================================================
#  SARA - System Automation & Response Agent  |  Version 2.0
#  Entry Point: CLI Wrapper
#
#  Usage:
#    sara -"Play an English song for me"
#    sara -"Open YouTube"
#    sara -"Search Google for Linux tips"
#    sara -"Clean trash"
#    sara -"Open Spotify"
#    sara -"Open Settings"
#    sara --help
#    sara --list
# =============================================================================

# ── Resolve SARA root regardless of where the binary is symlinked ────────────
SARA_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
export SARA_ROOT

# ── Source config ─────────────────────────────────────────────────────────────
CONFIG_FILE="$SARA_ROOT/config/sara.conf"
if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE"
else
    echo "[SARA] ERROR: Config file not found at $CONFIG_FILE"
    exit 1
fi

# ── Source utilities ──────────────────────────────────────────────────────────
source "$SARA_ROOT/utils/logger.sh"
source "$SARA_ROOT/utils/notify.sh"

# ── Ensure log directory exists ───────────────────────────────────────────────
mkdir -p "$SARA_LOG_DIR"

# ── Banner ────────────────────────────────────────────────────────────────────
print_banner() {
    echo ""
    echo "  ███████╗ █████╗ ██████╗  █████╗ "
    echo "  ██╔════╝██╔══██╗██╔══██╗██╔══██╗"
    echo "  ███████╗███████║██████╔╝███████║"
    echo "  ╚════██║██╔══██║██╔══██╗██╔══██║"
    echo "  ███████║██║  ██║██║  ██║██║  ██║"
    echo "  ╚══════╝╚═╝  ╚═╝╚═╝  ╚═╝╚═╝  ╚═╝"
    echo "  System Automation & Response Agent  v2.0"
    echo "  Agent: ${AGENT_NAME:-SARA}"
    echo ""
}

# ── Help ──────────────────────────────────────────────────────────────────────
print_help() {
    print_banner
    echo "  USAGE:"
    echo "    sara -\"<your command in plain English>\""
    echo "    sara <control command>"
    echo ""
    echo "  TASK EXAMPLES:"
    echo "    sara -\"Play a lofi song\""
    echo "    sara -\"Open YouTube\""
    echo "    sara -\"Search Google for Python tutorials\""
    echo "    sara -\"Search on Google about the French revolution\""
    echo "    sara -\"Open Spotify\""
    echo "    sara -\"Open Settings\""
    echo "    sara -\"Clean the trash\""
    echo ""
    echo "  CONTROL COMMANDS:"
    echo "    sara activate          Start SARA (monitor + cron watchdog)"
    echo "    sara stop              Stop SARA completely"
    echo "    sara restart           Stop then start again"
    echo "    sara status            Show what's running"
    echo ""
    echo "    sara -\"Activate sara\"  Same as above (natural English)"
    echo "    sara -\"Stop sara\"      Same as above (natural English)"
    echo ""
    echo "  LOG COMMANDS:"
    echo "    sara --logs            Live tail the event log"
    echo "    sara --errors          Show recent errors"
    echo "    sara --list            List all available actions"
    echo "    sara --help            Show this help"
    echo ""
    echo "  VOICE COMMANDS (v2.0):"
    echo "    sara voice-start       Start the voice listener daemon"
    echo "    sara voice-stop        Stop the voice listener daemon"
    echo "    sara voice-status      Show voice listener status"
    echo ""
    echo "  RENAME AGENT (v2.0):"
    echo "    sara rename \"JARVIS\"  Change the agent name / wake word"
    echo "    sara rename \"NOVA\"    (any single word)"
    echo ""
}

# ── List actions ──────────────────────────────────────────────────────────────
list_actions() {
    print_banner
    echo "  AVAILABLE HIGH-LEVEL ACTIONS:"
    echo "  ─────────────────────────────────────────────"
    echo "  [1]  play_song       → Play a song on YouTube"
    echo "  [2]  open_youtube    → Open YouTube in browser"
    echo "  [3]  search_google   → Search Google for a query"
    echo "  [4]  open_spotify    → Open Spotify (local or web)"
    echo "  [5]  open_settings   → Open system settings"
    echo "  [6]  clean_trash     → Permanently empty the Trash"
    echo "  ─────────────────────────────────────────────"
    echo ""
    echo "  AVAILABLE LOW-LEVEL ACTIONS (used internally):"
    echo "  ─────────────────────────────────────────────"
    echo "  mouse_click.py  mouse_move.py  type_text.py"
    echo "  key_press.py    scroll.py      screenshot.py"
    echo "  ─────────────────────────────────────────────"
    echo ""
}

# ── Argument Handling ─────────────────────────────────────────────────────────
if [[ $# -eq 0 ]]; then
    print_help
    exit 0
fi

case "$1" in
    --help|-h)
        print_help
        exit 0
        ;;
    --list|-l)
        list_actions
        exit 0
        ;;
    --logs)
        echo "[SARA] Tailing event log (Ctrl+C to stop)..."
        tail -f "$SARA_LOG_DIR/event_log.txt"
        exit 0
        ;;
    --errors)
        echo "[SARA] Recent errors:"
        echo "─────────────────────────────────────────────"
        tail -n 30 "$SARA_LOG_DIR/error_log.txt" 2>/dev/null || echo "No errors logged yet."
        exit 0
        ;;

    # ── STATUS ────────────────────────────────────────────────────────────────
    --status|status)
        echo ""
        echo "  SARA — System Status"
        echo "  ─────────────────────────────────────────────"

        # Monitor
        PID_FILE="$SARA_ROOT/core/monitor.pid"
        if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "  Monitor   : ✓ RUNNING  (PID: $(cat "$PID_FILE"))"
        else
            echo "  Monitor   : ✗ STOPPED"
        fi

        # Cron watchdog
        if crontab -l 2>/dev/null | grep -q "SARA_MANAGED"; then
            echo "  Cron jobs : ✓ INSTALLED"
        else
            echo "  Cron jobs : ✗ NOT installed"
        fi

        # AT queue
        AT_COUNT=$(atq 2>/dev/null | wc -l)
        echo "  AT queue  : $AT_COUNT job(s) pending"

        # Log sizes
        EVENT_SIZE=$(wc -l < "$SARA_LOG_DIR/event_log.txt" 2>/dev/null || echo 0)
        ERROR_SIZE=$(wc -l < "$SARA_LOG_DIR/error_log.txt" 2>/dev/null || echo 0)
        echo "  Event log : $EVENT_SIZE lines"
        echo "  Error log : $ERROR_SIZE lines"
        echo "  ─────────────────────────────────────────────"
        echo ""
        exit 0
        ;;

    # ── VOICE START ───────────────────────────────────────────────────────────
    voice-start|voice_start|--voice-start)
        echo ""
        echo "  [SARA] Starting voice listener..."
        echo "  ─────────────────────────────────────────────"

        VOICE_PID_FILE="$SARA_ROOT/core/voice_listener.pid"

        # Already running?
        if [[ -f "$VOICE_PID_FILE" ]] && kill -0 "$(cat "$VOICE_PID_FILE")" 2>/dev/null; then
            echo "  Voice listener already running (PID: $(cat "$VOICE_PID_FILE"))"
            exit 0
        fi

        export SARA_LOG_DIR="$SARA_LOG_DIR"
        python3 "$SARA_ROOT/core/voice_listener.py" &>/dev/null &
        VOICE_PID=$!
        sleep 1

        if [[ -f "$VOICE_PID_FILE" ]] && kill -0 "$(cat "$VOICE_PID_FILE")" 2>/dev/null; then
            echo "  ✓ Voice listener started (PID: $(cat "$VOICE_PID_FILE"))"
            echo "  Listening for wake word: \"${AGENT_NAME:-SARA}\""
            sara_log_event "SARA_VOICE" "Voice listener started"
        else
            echo "  ⚠  Voice listener started — PID not yet confirmed."
            echo "     Check logs: sara --logs"
        fi
        echo "  ─────────────────────────────────────────────"
        echo ""
        sara_notify "${AGENT_NAME:-SARA} Voice" "Voice listener active 🎤"
        exit 0
        ;;

    # ── VOICE STOP ────────────────────────────────────────────────────────────
    voice-stop|voice_stop|--voice-stop)
        echo ""
        echo "  [SARA] Stopping voice listener..."
        VOICE_PID_FILE="$SARA_ROOT/core/voice_listener.pid"

        if [[ -f "$VOICE_PID_FILE" ]]; then
            VPID=$(cat "$VOICE_PID_FILE")
            if kill -0 "$VPID" 2>/dev/null; then
                kill "$VPID"
                sleep 1
                kill -0 "$VPID" 2>/dev/null && kill -9 "$VPID" 2>/dev/null
                echo "  ✓ Voice listener stopped (was PID: $VPID)"
                sara_log_event "SARA_VOICE" "Voice listener stopped"
            else
                echo "  Voice listener was not running."
            fi
            rm -f "$VOICE_PID_FILE"
        else
            # Try by process name
            VPID=$(pgrep -f "voice_listener.py" | head -1)
            if [[ -n "$VPID" ]]; then
                kill "$VPID"
                echo "  ✓ Voice listener stopped (PID: $VPID)"
            else
                echo "  Voice listener is not running."
            fi
        fi
        sara_notify "${AGENT_NAME:-SARA} Voice" "Voice listener stopped 🔴"
        echo ""
        exit 0
        ;;

    # ── VOICE STATUS ──────────────────────────────────────────────────────────
    voice-status|voice_status|--voice-status)
        echo ""
        echo "  SARA Voice — Status"
        echo "  ─────────────────────────────────────────────"
        VOICE_PID_FILE="$SARA_ROOT/core/voice_listener.pid"
        if [[ -f "$VOICE_PID_FILE" ]] && kill -0 "$(cat "$VOICE_PID_FILE")" 2>/dev/null; then
            echo "  Voice listener : ✓ RUNNING (PID: $(cat "$VOICE_PID_FILE"))"
        else
            echo "  Voice listener : ✗ STOPPED"
        fi
        echo "  Wake word      : ${AGENT_NAME:-SARA}"
        ENGINE=$(grep "^SARA_VOICE_ENGINE" "$SARA_ROOT/config/sara.conf" 2>/dev/null | cut -d= -f2 | tr -d '"')
        echo "  Engine         : ${ENGINE:-vosk}"
        echo "  ─────────────────────────────────────────────"
        echo ""
        exit 0
        ;;

    # ── RENAME ────────────────────────────────────────────────────────────────
    rename|--rename)
        NEW_NAME="${2:-}"
        if [[ -z "$NEW_NAME" ]]; then
            echo "[SARA] ERROR: Provide a new name. Example: sara rename \"JARVIS\""
            exit 1
        fi

        # Validate: single word, letters only, 2-20 chars
        if ! echo "$NEW_NAME" | grep -qE '^[A-Za-z]{2,20}$'; then
            echo "[SARA] ERROR: Agent name must be letters only, 2-20 characters."
            echo "  Examples: JARVIS  NOVA  ALEX  MAX"
            exit 1
        fi

        NEW_NAME_UPPER=$(echo "$NEW_NAME" | tr '[:lower:]' '[:upper:]')
        OLD_NAME="${AGENT_NAME:-SARA}"
        CONF_FILE="$SARA_ROOT/config/sara.conf"

        echo ""
        echo "  [SARA] Renaming agent..."
        echo "  ${OLD_NAME} → ${NEW_NAME_UPPER}"
        echo ""

        # Backup config first
        cp "$CONF_FILE" "${CONF_FILE}.bak"

        # Replace AGENT_NAME line in config
        sed -i "s/^AGENT_NAME=.*/AGENT_NAME="${NEW_NAME_UPPER}"/" "$CONF_FILE"

        if grep -q "AGENT_NAME="${NEW_NAME_UPPER}"" "$CONF_FILE"; then
            echo "  ✓ Config updated: AGENT_NAME="${NEW_NAME_UPPER}""
            sara_log_event "SARA_RENAME" "Agent renamed: $OLD_NAME → $NEW_NAME_UPPER"
        else
            echo "  ✗ Failed to update config. Restoring backup."
            cp "${CONF_FILE}.bak" "$CONF_FILE"
            exit 1
        fi

        # Hot-reload voice listener if running (SIGHUP = reload config)
        VOICE_PID_FILE="$SARA_ROOT/core/voice_listener.pid"
        if [[ -f "$VOICE_PID_FILE" ]] && kill -0 "$(cat "$VOICE_PID_FILE")" 2>/dev/null; then
            kill -HUP "$(cat "$VOICE_PID_FILE")"
            echo "  ✓ Voice listener reloaded — now listening for: ${NEW_NAME_UPPER}"
        else
            echo "  (Voice listener not running — rename takes effect on next start)"
        fi

        echo ""
        echo "  ✓ Done. Your agent is now named: ${NEW_NAME_UPPER}"
        echo "  Speak '${NEW_NAME_UPPER}' to activate voice commands."
        echo ""
        sara_notify "Agent Renamed" "${OLD_NAME} is now ${NEW_NAME_UPPER} 🔄"
        exit 0
        ;;

    # ── ACTIVATE / START ──────────────────────────────────────────────────────
    # Accepts:  sara activate   |   sara start   |   Activate sara (via dispatcher)
    activate|start|--start|--activate)
        echo ""
        echo "  [SARA] Activating..."
        echo "  ─────────────────────────────────────────────"

        # 1. Start monitor if not already running
        PID_FILE="$SARA_ROOT/core/monitor.pid"
        if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
            echo "  Monitor   : already running (PID: $(cat "$PID_FILE"))"
        else
            export SARA_LOG_DIR="$SARA_LOG_DIR"
            python3 "$SARA_ROOT/core/monitor.py" &>/dev/null &
            sleep 1
            if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
                echo "  Monitor   : ✓ Started (PID: $(cat "$PID_FILE"))"
                sara_log_event "SARA_CONTROL" "SARA activated — monitor started"
            else
                echo "  Monitor   : ⚠ Started but PID not confirmed yet"
            fi
        fi

        # 2. Install cron watchdog if not already installed
        if crontab -l 2>/dev/null | grep -q "SARA_MANAGED"; then
            echo "  Cron jobs : already installed"
        else
            bash "$SARA_ROOT/core/scheduler.sh" install > /dev/null
            echo "  Cron jobs : ✓ Installed"
        fi

        # 3. Auto-start voice listener if configured
        if [[ "${SARA_VOICE_AUTO_START:-false}" == "true" ]]; then
            VOICE_PID_FILE="$SARA_ROOT/core/voice_listener.pid"
            if [[ -f "$VOICE_PID_FILE" ]] && kill -0 "$(cat "$VOICE_PID_FILE")" 2>/dev/null; then
                echo "  Voice     : already listening"
            else
                python3 "$SARA_ROOT/core/voice_listener.py" &>/dev/null &
                sleep 1
                echo "  Voice     : ✓ Started (wake word: ${AGENT_NAME:-SARA})"
                sara_log_event "SARA_VOICE" "Voice listener auto-started"
            fi
        else
            echo "  Voice     : off (run 'sara voice-start' to enable)"
        fi

        echo "  ─────────────────────────────────────────────"
        echo "  ✓ ${AGENT_NAME:-SARA} is active and listening."
        echo ""
        sara_notify "${AGENT_NAME:-SARA}" "${AGENT_NAME:-SARA} is now active 🟢"
        exit 0
        ;;

    # ── STOP ─────────────────────────────────────────────────────────────────
    stop|--stop|deactivate|--deactivate)
        echo ""
        echo "  [SARA] Stopping..."
        echo "  ─────────────────────────────────────────────"

        # 1. Remove cron watchdog FIRST (so it can't restart monitor)
        if crontab -l 2>/dev/null | grep -q "SARA_MANAGED"; then
            bash "$SARA_ROOT/core/scheduler.sh" remove > /dev/null
            echo "  Cron jobs : ✓ Removed"
        else
            echo "  Cron jobs : already clear"
        fi

        # 2. Kill the monitor
        PID_FILE="$SARA_ROOT/core/monitor.pid"
        if [[ -f "$PID_FILE" ]]; then
            MONITOR_PID=$(cat "$PID_FILE")
            if kill -0 "$MONITOR_PID" 2>/dev/null; then
                kill "$MONITOR_PID"
                sleep 1
                # Force kill if still alive
                if kill -0 "$MONITOR_PID" 2>/dev/null; then
                    kill -9 "$MONITOR_PID" 2>/dev/null
                fi
                echo "  Monitor   : ✓ Stopped (was PID: $MONITOR_PID)"
            else
                echo "  Monitor   : already stopped"
            fi
            rm -f "$PID_FILE"
        else
            # Try finding by process name as fallback
            FOUND_PID=$(pgrep -f "monitor.py" 2>/dev/null | head -1)
            if [[ -n "$FOUND_PID" ]]; then
                kill "$FOUND_PID"
                echo "  Monitor   : ✓ Stopped (PID: $FOUND_PID)"
            else
                echo "  Monitor   : already stopped"
            fi
        fi

        # 3. Clear the AT job queue
        AT_JOBS=$(atq 2>/dev/null | awk '{print $1}')
        if [[ -n "$AT_JOBS" ]]; then
            echo "$AT_JOBS" | xargs -r atrm 2>/dev/null
            echo "  AT queue  : ✓ Cleared"
        else
            echo "  AT queue  : already empty"
        fi

        sara_log_event "SARA_CONTROL" "SARA stopped by user"
        echo "  ─────────────────────────────────────────────"
        echo "  ✓ SARA is fully stopped."
        echo ""
        sara_notify "SARA" "SARA has been stopped 🔴"
        exit 0
        ;;

    # ── RESTART ───────────────────────────────────────────────────────────────
    restart|--restart)
        echo "[SARA] Restarting..."
        sara_log_event "SARA_CONTROL" "Restart requested"
        bash "$SARA_ROOT/sara" stop
        sleep 1
        bash "$SARA_ROOT/sara" activate
        exit 0
        ;;
esac

# ── Parse the command string ──────────────────────────────────────────────────
# Accept:  sara -"..."   or   sara -'...'   or   sara "..."
RAW_INPUT="$1"
# Strip leading dash/quote characters
USER_COMMAND="${RAW_INPUT#-}"       # remove leading -
USER_COMMAND="${USER_COMMAND#\"}"   # remove leading "
USER_COMMAND="${USER_COMMAND%\"}"   # remove trailing "
USER_COMMAND="${USER_COMMAND#\'}"   # remove leading '
USER_COMMAND="${USER_COMMAND%\'}"   # remove trailing '

if [[ -z "$USER_COMMAND" ]]; then
    sara_log_error "SARA_ENTRY" "Empty command received."
    echo "[SARA] ERROR: No command provided. Use sara --help for usage."
    exit 1
fi

# ── Log the incoming request ──────────────────────────────────────────────────
sara_log_event "SARA_ENTRY" "User command received: \"$USER_COMMAND\""
sara_notify "SARA" "Processing: \"$USER_COMMAND\""

echo ""
echo "[SARA] Received: \"$USER_COMMAND\""
echo "[SARA] Dispatching..."
echo ""

# ── Step 1: Dispatch → get action + extracted query ──────────────────────────
DISPATCH_RESULT=$(python3 "$SARA_ROOT/core/dispatcher.py" "$USER_COMMAND" 2>&1)
DISPATCH_EXIT=$?

if [[ $DISPATCH_EXIT -ne 0 ]]; then
    sara_log_error "SARA_DISPATCHER" "Dispatcher failed: $DISPATCH_RESULT"
    echo "[SARA] ERROR: Could not dispatch command. See error log."
    sara_notify "SARA Error" "Could not understand: $USER_COMMAND"
    exit 1
fi

# dispatcher.py outputs: ACTION_NAME|EXTRACTED_QUERY
ACTION_NAME=$(echo "$DISPATCH_RESULT" | cut -d'|' -f1)
EXTRACTED_QUERY=$(echo "$DISPATCH_RESULT" | cut -d'|' -f2)

if [[ "$ACTION_NAME" == "UNKNOWN" ]]; then
    sara_log_error "SARA_DISPATCHER" "No matching action for: \"$USER_COMMAND\""
    echo "[SARA] Sorry, I don't know how to handle: \"$USER_COMMAND\""
    echo "[SARA] Use 'sara --list' to see available actions."
    sara_notify "SARA" "Unknown command. Try 'sara --list'"
    exit 1
fi

# ── Intercept control commands from dispatcher ────────────────────────────────
# If the user typed "Activate sara" or "Stop sara" as a natural sentence,
# dispatcher returns activate/stop/restart/status — route them back into
# the control commands rather than treating them as action scripts.
case "$ACTION_NAME" in
    activate|start)
        sara_log_event "SARA_DISPATCHER" "Control command intercepted: activate"
        exec bash "$SARA_ROOT/sara" activate
        ;;
    stop|deactivate)
        sara_log_event "SARA_DISPATCHER" "Control command intercepted: stop"
        exec bash "$SARA_ROOT/sara" stop
        ;;
    restart)
        sara_log_event "SARA_DISPATCHER" "Control command intercepted: restart"
        exec bash "$SARA_ROOT/sara" restart
        ;;
    status)
        sara_log_event "SARA_DISPATCHER" "Control command intercepted: status"
        exec bash "$SARA_ROOT/sara" status
        ;;
    voice-start)
        sara_log_event "SARA_DISPATCHER" "Control command intercepted: voice-start"
        exec bash "$SARA_ROOT/sara" voice-start
        ;;
    voice-stop)
        sara_log_event "SARA_DISPATCHER" "Control command intercepted: voice-stop"
        exec bash "$SARA_ROOT/sara" voice-stop
        ;;
esac

sara_log_event "SARA_DISPATCHER" "Matched action: $ACTION_NAME | Query: \"$EXTRACTED_QUERY\""
echo "[SARA] Action selected : $ACTION_NAME"
echo "[SARA] Extracted query : \"$EXTRACTED_QUERY\""
echo ""

# ── Step 2: Validate the action script ───────────────────────────────────────
ACTION_SCRIPT="$SARA_ROOT/actions/high_level/${ACTION_NAME}.sh"

if [[ ! -f "$ACTION_SCRIPT" ]]; then
    sara_log_error "SARA_VALIDATOR" "Action script not found: $ACTION_SCRIPT"
    echo "[SARA] ERROR: Action script missing: $ACTION_SCRIPT"
    exit 1
fi

echo "[SARA] Running security validator..."
VALIDATION_RESULT=$(python3 "$SARA_ROOT/core/validator.py" "$ACTION_SCRIPT" 2>&1)
VALIDATION_EXIT=$?

if [[ $VALIDATION_EXIT -ne 0 ]]; then
    sara_log_error "SARA_VALIDATOR" "Validation FAILED for $ACTION_NAME: $VALIDATION_RESULT"
    echo "[SARA] ✗ SECURITY CHECK FAILED — Action aborted."
    echo "[SARA] Reason: $VALIDATION_RESULT"
    sara_notify "SARA Security" "Action blocked: $ACTION_NAME"
    exit 1
fi

sara_log_event "SARA_VALIDATOR" "Validation PASSED for: $ACTION_NAME"
echo "[SARA] ✓ Security check passed."
echo ""

# ── Step 3: Schedule via 'at' for immediate non-overlapping execution ─────────
echo "[SARA] Scheduling action with 'at'..."
AT_JOB_CMD="bash $ACTION_SCRIPT \"$EXTRACTED_QUERY\" >> $SARA_LOG_DIR/event_log.txt 2>> $SARA_LOG_DIR/error_log.txt"

echo "$AT_JOB_CMD" | at now 2>/dev/null
AT_EXIT=$?

if [[ $AT_EXIT -eq 0 ]]; then
    sara_log_event "SARA_SCHEDULER" "Action '$ACTION_NAME' queued via 'at'"
    echo "[SARA] ✓ Action '$ACTION_NAME' queued for execution."
    sara_notify "SARA" "Running: $ACTION_NAME"
else
    # Fallback: run directly if 'at' is not available
    sara_log_event "SARA_SCHEDULER" "'at' unavailable, running '$ACTION_NAME' directly"
    echo "[SARA] 'at' not available — running directly..."
    bash "$ACTION_SCRIPT" "$EXTRACTED_QUERY"
fi

echo ""
echo "[SARA] Done. Check logs with: sara --logs"
echo ""
